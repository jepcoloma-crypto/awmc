# Set to 'true' to use MSW mock data instead of real backend
# Leave empty or 'false' to use real API (requires server running)
VITE_USE_MOCKS=false

# Backend API URL (only needed for production/Vercel)
# In dev, Vite proxies /api to localhost:3001 automatically
# VITE_API_URL=https://your-backend.com
